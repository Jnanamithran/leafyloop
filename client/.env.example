# ─── CLIENT ENVIRONMENT VARIABLES ─────────────────────────────────────────────
# Copy to .env and fill in values

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# WhatsApp business number (country code + number, no spaces or +)
VITE_WA_NUMBER=919447000000

# Razorpay Key ID (public — safe to expose on client)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Firebase Config (get from Firebase → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=1:123456789:web:abcdefabcdef
