# ─── SERVER ENVIRONMENT VARIABLES ─────────────────────────────────────────────
# Copy this file to .env and fill in all values before running

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/leafyloop?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_access_token_key_min_64_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_64_chars

# ── Razorpay ───────────────────────────────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Cloudinary ─────────────────────────────────────────────────────────────────
# Get from Cloudinary Dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Nodemailer (Gmail SMTP) ────────────────────────────────────────────────────
# For Gmail: enable 2FA → App Passwords → Generate password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ── Firebase Admin (for Google OAuth) ─────────────────────────────────────────
# Download Service Account JSON from Firebase → Project Settings → Service Accounts
# Then encode: base64 -i serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
